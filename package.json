{
  "name": "codesurf",
  "version": "0.1.0",
  "productName": "CodeSurf",
  "description": "Infinite canvas workspace for AI agents",
  "main": "dist-electron/main/index.js",
  "bin": {
    "codesurf": "bin/codesurf.cjs"
  },
  "files": [
    "bin/",
    "dist-electron/",
    "packages/contex-relay/dist/",
    "resources/",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "electron-vite dev -- --js-flags=\"--expose-gc --max-old-space-size=${CODESURF_MAX_OLD_SPACE_SIZE_MB:-8192}\"",
    "build:main": "EV_BUILD_TARGET=main electron-vite build",
    "build:preload": "EV_BUILD_TARGET=preload electron-vite build",
    "build:renderer": "EV_BUILD_TARGET=renderer electron-vite build",
    "build": "EV_BUILD_TARGET=main electron-vite build && EV_BUILD_TARGET=preload electron-vite build && EV_BUILD_TARGET=renderer electron-vite build",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "release:github": "npm run build && electron-builder --mac dmg zip --publish always",
    "dogfood": "electron-vite build && electron-vite preview",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w node-pty,better-sqlite3",
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3"
  },
  "keywords": [],
  "author": "Jason",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.79",
    "@monaco-editor/react": "^4.7.0",
    "@opencode-ai/sdk": "^1.2.27",
    "@streamdown/code": "^1.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "elkjs": "^0.11.1",
    "lucide-react": "^0.468.0",
    "morphcloud": "^0.0.20",
    "node-pty": "^1.1.0",
    "react-file-icon": "^1.5.0",
    "sharp": "^0.34.5",
    "streamdown": "^2.5.0",
    "web-worker": "^1.3.0",
    "xterm": "^5.3.0"
  },
  "build": {
    "appId": "com.huggiapps.codesurf",
    "productName": "CodeSurf",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "package.json",
      "resources/**/*"
    ],
    "asar": true,
    "icon": "resources/icon.png",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png"
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "npmRebuild": false,
    "linux": {
      "category": "Development",
      "icon": "resources/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jkneen",
        "repo": "collaborator-clone"
      }
    ]
  }
}
