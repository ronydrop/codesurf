{
  "name": "contex",
  "version": "0.1.0",
  "description": "Infinite canvas workspace for AI agents",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "electron-vite dev",
    "build:main": "EV_BUILD_TARGET=main electron-vite build",
    "build:preload": "EV_BUILD_TARGET=preload electron-vite build",
    "build:renderer": "EV_BUILD_TARGET=renderer electron-vite build",
    "build": "EV_BUILD_TARGET=main electron-vite build && EV_BUILD_TARGET=preload electron-vite build && EV_BUILD_TARGET=renderer electron-vite build",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "release:github": "npm run build && electron-builder --mac dmg zip --publish always",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "keywords": [],
  "author": "Jason",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.79",
    "@monaco-editor/react": "^4.7.0",
    "@opencode-ai/sdk": "^1.2.27",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "elkjs": "^0.11.1",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "react-file-icon": "^1.5.0",
    "sharp": "^0.34.5",
    "web-worker": "^1.3.0",
    "xterm": "^5.3.0"
  },
  "optionalDependencies": {
    "cluso-widget": "file:../agentation-real"
  },
  "build": {
    "appId": "com.huggiapps.contex",
    "productName": "Contex",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jkneen",
        "repo": "collaborator-clone"
      }
    ]
  }
}
